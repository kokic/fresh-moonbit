{
  "$schema": "https://raw.githubusercontent.com/sinelaw/fresh/main/crates/fresh-editor/plugins/schemas/package.schema.json",
  "name": "moonbit",
  "version": "0.0.1",
  "description": "MoonBit programming language support - syntax highlighting, LSP integration, and installation helpers",
  "type": "bundle",
  "author": "kokic",
  "license": "MIT",
  "keywords": ["moonbit"],
  "fresh": {
    "languages": [
      {
        "id": "moonbit",
        "grammar": {
          "file": "grammars/MoonBit.sublime-syntax",
          "extensions": ["mbt", "mbti"]
        },
        "language": {
          "commentPrefix": "//",
          "tabSize": 2,
          "useTabs": false,
          "autoIndent": true
        }
      }
    ]
  }
}